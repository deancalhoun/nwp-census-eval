# Load necessary modules
module purge
module load eccodes

# Add eccodes binary path to PATH
export PATH=$PATH:/glade/u/apps/derecho/24.12/spack/opt/spack/eccodes/2.34.0/oneapi/2024.2.1/m3t3/bin

# Change to the directory from which the job was submitted
cd $PBS_O_WORKDIR

# Run script
./convert_ecmwf_an.sh