# Load necessary modules
module purge
module load conda

# Activate your Conda environment
conda activate censuswxindex

# Change to the directory from which the job was submitted
cd $PBS_O_WORKDIR

# Run Python script
python -u /glade/u/home/dcalhoun/CensusWxIndex/censuswxindex/aggregate_2t.py --year $YEAR